# ── Telegram 通知 ──
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── Binance API (Paper Trading 不需要) ──
BINANCE_API_KEY=your_key
BINANCE_API_SECRET=your_secret

# ── 数据存储 ──
DATA_DIR=./data

# ── 代理（可选）──
HTTP_PROXY=
HTTPS_PROXY=

# ── OI 數據 Provider（研究用）──
# Coinglass: 免費 API 提供 2020 年至今的歷史 OI
# 註冊: https://www.coinglass.com/pricing
COINGLASS_API_KEY=your_coinglass_api_key

# ── Instagram + Threads 自動發文（scripts/post_dca_social.py）──
# ⚠️ Threads 與 Instagram 是「兩個不同」的 OAuth / 不同的 host / 不同的 token，
#    同一個 token 不能互用（會 error 190）。所以這裡分開兩組憑證。
#
# Instagram Content Publishing API（host: graph.facebook.com，Facebook Login）
#   權限: instagram_basic, instagram_content_publish, pages_read_engagement
#   IG 必須是「商業/創作者」帳號並連結 Facebook 粉專。
META_ACCESS_TOKEN=your_meta_long_lived_token
IG_USER_ID=your_ig_business_user_id
# 若改用 Instagram Login 流程，把 host 設成 https://graph.instagram.com
# IG_GRAPH_HOST=https://graph.facebook.com
# GRAPH_API_VERSION=v21.0
#
# Threads API（host: graph.threads.net/v1.0）
#   權限: threads_basic, threads_content_publish
#   THREADS_USER_ID 與 THREADS_ACCESS_TOKEN 來自 Threads 專屬的 OAuth 流程。
#   若不填 THREADS_ACCESS_TOKEN，程式會 fallback 用 META_ACCESS_TOKEN（多半會失敗）。
THREADS_USER_ID=your_threads_user_id
THREADS_ACCESS_TOKEN=your_threads_access_token
#
# IG 發圖需要「公開可讀的 HTTPS 圖片 URL」(Meta 會 server-side 抓取)。三選一：
#   1) imgbb：最低成本，設 IMGBB_API_KEY 即可
#   2) 自架/儀表板靜態檔：設 PUBLIC_IMAGE_BASE_URL(+ 可選 PUBLIC_IMAGE_DIR)
IMGBB_API_KEY=
PUBLIC_IMAGE_BASE_URL=
PUBLIC_IMAGE_DIR=
#
# 報表圖 CJK 字型（預設自動偵測 macOS/Linux 常見字型，可手動指定 .ttc/.otf/.ttf）
DCA_REPORT_FONT=
